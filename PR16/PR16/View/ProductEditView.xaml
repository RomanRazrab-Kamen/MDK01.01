<Window x:Class="PR16.View.ProductEditView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR16.View"
        mc:Ignorable="d"
        Title="Редактирование товара" Height="640" Width="400" WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Name="TextBlockHeader" Text="Добавление нового товара" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Артикул:" Margin="0,5,0,2"/>
                <ComboBox Name="ComboBarcode" DisplayMemberPath="Наименование"/>

                <TextBlock Text="Тип товара:" Margin="0,5,0,2"/>
                <ComboBox Name="ComboType" DisplayMemberPath="ТипТовара"/>

                <TextBlock Text="Единица измерения:" Margin="0,5,0,2"/>
                <ComboBox Name="ComboUnit" DisplayMemberPath="Наименование"/>

                <TextBlock Text="Поставщик:" Margin="0,5,0,2"/>
                <ComboBox Name="ComboSupplier" DisplayMemberPath="Наименование"/>

                <TextBlock Text="Производитель:" Margin="0,5,0,2"/>
                <ComboBox Name="ComboManufacturer" DisplayMemberPath="Наименование"/>

                <TextBlock Text="Категория товара:" Margin="0,5,0,2"/>
                <ComboBox Name="ComboCategory" DisplayMemberPath="Наименование"/>

                <TextBlock Text="Цена:" Margin="0,5,0,2"/>
                <TextBox Name="TextBoxPrice"/>

                <TextBlock Text="Действующая скидка (%):" Margin="0,5,0,2"/>
                <TextBox Name="TextBoxDiscount"/>

                <TextBlock Text="Количество на складе:" Margin="0,5,0,2"/>
                <TextBox Name="TextBoxCount"/>

                <TextBlock Text="Описание товара:" Margin="0,5,0,2"/>
                <TextBox Name="TextBoxDescription" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Name="ButtonSave" Width="100" Margin="0,0,10,0" Background="LightGreen" Click="ButtonSaveClick"/>
            <Button Content="Отмена" Name="ButtonCancel" Width="100" Background="LightGray" Click="ButtonCancelClick"/>
        </StackPanel>
    </Grid>
</Window>
