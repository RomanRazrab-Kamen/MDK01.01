<Window x:Class="PR18.Views.AddAnimalView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR18.Views"
        mc:Ignorable="d"
        Title="AddAnimalView" Height="650" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Новый обитатель зоопарка" FontSize="20" FontWeight="Bold" Foreground="#333" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="Название животного:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                <TextBox Name="TxtName" Padding="5" Margin="0,0,0,10"/>

                <TextBlock Text="Описание:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                <TextBox Name="TxtDescription" Padding="5" MinHeight="60" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,10"/>

                <TextBlock Text="Интересный факт:" FontWeight="SemiBold" Margin="0,5,0,2"/>
                <TextBox Name="TxtFact" Padding="5" MinHeight="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,15"/>

               
                <StackPanel>
                    <TextBlock Text="Изображение животного" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Image Name="ImgPreview" Height="100" Width="130" Stretch="UniformToFill" HorizontalAlignment="Left"/>
                        <Button Grid.Column="1" Content="Выбрать фото" Click="ButtonSelectImage_Click" Padding="10,5" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Звуковое сопровождение" FontSize="13" FontWeight="Bold" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Name="TxtSoundPath" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1" Content="Выбрать звук" Click="ButtonSelectSound_Click" Padding="10,5" VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Click="ButtonSave_Click" Width="100" Height="30" Margin="0,0,10,0"/>
            <Button Content="Отмена" Click="ButtonCancel_Click" Width="100" Height="30"/>
        </StackPanel>
    </Grid>
</Window>
