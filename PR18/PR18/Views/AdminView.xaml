<Window x:Class="PR18.Views.AdminView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR18.Views"
        xmlns:services="clr-namespace:PR18.Services"
        mc:Ignorable="d"
        Title="Виртуальный зоопарк - Режим Администратора" Height="580" Width="800">
    <Window.Resources>
        <services:BytesToImageConverter x:Key="BytesToImageConverter"/>
    </Window.Resources>
    <Grid>
        <TabControl>
            <TabItem Header="Обитатели зоопарка">
                <Grid>
                    <Grid.ColumnDefinitions >
                        <ColumnDefinition Width ="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Коммандная панель" Margin="10,10,10,10"/>
                        <Button Content="Удалить животное" Margin="10,0,10,10" Click="Button_DeleteAnimal"/>
                        <Button Content="Добавить животное" Margin="10,0,10,10" Click="Button_AddAnimal"/>
                        <Button Content="Изменить животное" Margin="10,0,10,10" Click="Button_EditAnimal"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Список животных" Margin="10"/>
                        <ListBox Grid.Row="1" 
                            Name="AnimalsListBox" 
                            Margin="10" 
                            BorderThickness="0"
                            Height="400"
                            ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>

                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="15" Width="160">
                                        <Border BorderBrush="#498C51" 
                                            BorderThickness="2" 
                                            CornerRadius="8" 
                                            Height="140" 
                                            Background="White">
                                            <Image 
                                                Source="{Binding Image, 
                                                Converter={StaticResource BytesToImageConverter}}"/>
                                        </Border>

                                        <TextBlock Text="{Binding Name}" 
                                           FontWeight="Bold" 
                                           HorizontalAlignment="Center" 
                                           Margin="0,8,0,0" 
                                           FontSize="15"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>

                </Grid>
            </TabItem>
            <TabItem Header="Пользователи">

            </TabItem>
        </TabControl>
    </Grid>
</Window>
