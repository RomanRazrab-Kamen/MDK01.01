<Window x:Class="PR15Hash.Views.Regisration"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR15Hash.Views"
        mc:Ignorable="d"
        Title="Регистрация" 
        Height="720" 
        Width="400">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="20">
            <TextBlock Text="Регистрация" HorizontalAlignment="Center" Margin="20" FontSize="28" FontWeight="Bold"/>
            <TextBlock Text="Фамилия" Margin="10,10,10,0"/>
            <TextBox Name="TextBoxSurname" MaxLength="255" Margin="10"/>
            <TextBlock Text="Имя" Margin="10,10,10,0"/>
            <TextBox Name="TextBoxName" MaxLength="255"  Margin="10"/>
            <TextBlock Text="Отчество" Margin="10,10,10,0"/>
            <TextBox Name="TextBoxPatronymic" MaxLength="255"  Margin="10"/>
            <TextBlock Text="Логин" Margin="10,10,10,0"/>
            <TextBox Name="TextBoxLogin" MaxLength="255"  Margin="10"/>
            <TextBlock Text="E-mail" Margin="10,10,10,0"/>
            <TextBox Name="TextBoxEmail" MaxLength="255"  Margin="10"/>
            <TextBlock Text="Пароль" Margin="10,10,10,0"/>
            <TextBox Name="TextBoxPassword" MaxLength="255"  Margin="10"/>
            <TextBlock Text="Подтвердите пароль" Margin="10,10,10,0"/>
            <TextBox Name="TextBoxConfirmPassword" MaxLength="255"  Margin="10"/>
            <StackPanel Orientation="Horizontal">
                <Button Name="ButtonAuthorization" Content="Авторизация" Margin="10" Height="30" Width="150" Click="ButtonAuthorization_Click"/>
                <Button Name="ButtonRegistration" Content="Зарегистрироватся" Margin="20,0,0,0" Height="30" Width="150" Click="ButtonRegistration_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
