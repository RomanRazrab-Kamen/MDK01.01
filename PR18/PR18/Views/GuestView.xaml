<Window x:Class="PR18.Views.GuestView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PR18.Views"
        xmlns:services="clr-namespace:PR18.Services"
        mc:Ignorable="d"
        Title="Виртуальный зоопарк — Режим Гостя" 
        Height="450" Width="800"
        Background="White" 
        FontFamily="Comic Sans MS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#76E383" Padding="15,0">
            <Grid>
                <TextBlock Text="Гостевой режим" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="Black"
                           VerticalAlignment="Center"/>

                <Button Content="Зарегистрироваться" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Background="#498C51" 
                        Foreground="White" 
                        FontWeight="Bold"
                        Padding="15,8"
                        Click="RegisterButton_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="3"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <ListBox Grid.Row="1" 
                 Name="AnimalsListBox" 
                 Margin="10" 
                 BorderThickness="0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel IsItemsHost="True" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="15" Width="160">
                        <Border BorderBrush="#498C51" 
                                BorderThickness="2" 
                                CornerRadius="8" 
                                Height="140" 
                                Background="White"
                                ClipToBounds="True">
                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                        </Border>

                        <TextBlock Text="{Binding Name}" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Center" 
                                   Margin="0,8,0,0" 
                                   FontSize="15"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>